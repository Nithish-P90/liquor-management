# ──────────────────────────────────────────────────────────────────────────────
# COPY THIS FILE AND FILL IN YOUR VALUES
# On Render: Dashboard → Your Service → Environment → "Add from .env" and upload
# DO NOT commit the filled-in file — .env is already in .gitignore
# ──────────────────────────────────────────────────────────────────────────────

# ── Database (Neon PostgreSQL) ─────────────────────────────────────────────────
# Get both strings from: Neon Console → Your Project → Connection Details
# Use the "Pooled connection" string for DATABASE_URL
DATABASE_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require&pgbouncer=true

# Use the "Direct connection" string for DIRECT_URL (needed for Prisma migrations)
DIRECT_URL=postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/DBNAME?sslmode=require

# ── NextAuth ──────────────────────────────────────────────────────────────────
# Your deployed Render URL (no trailing slash)
NEXTAUTH_URL=https://YOUR-APP-NAME.onrender.com

# Generate a random secret — run: openssl rand -hex 32
NEXTAUTH_SECRET=REPLACE_WITH_RANDOM_32_BYTE_HEX_SECRET

# ── Sync API (electron ↔ server) ──────────────────────────────────────────────
# Any long random string — used to authenticate sync requests from the desktop app
SYNC_TOKEN=REPLACE_WITH_RANDOM_TOKEN

# ── Cron job auth ─────────────────────────────────────────────────────────────
# Used by /api/cron/rollover — must match what your cron caller sends as Bearer token
CRON_SECRET=REPLACE_WITH_RANDOM_SECRET

# ── Optional overrides ────────────────────────────────────────────────────────
# Emergency login PIN if DB is unreachable (defaults to 1006 if not set)
# FALLBACK_PIN=1006
# ALLOW_PIN_FALLBACK=true

# =====================================================
# Render Environment Variables (.env.example)
# =====================================================
# Copy these keys into Render -> Service -> Environment.

# -----------------------------------------------------
# Required: Database
# -----------------------------------------------------
# Use pooled connection string for Prisma client runtime.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connect_timeout=15"

# Use direct connection string for migrations.
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&connect_timeout=15"

# -----------------------------------------------------
# Required: Auth
# -----------------------------------------------------
# Generate a strong random value (32+ chars).
NEXTAUTH_SECRET="replace-with-random-32-plus-char-secret"

# Render public app URL.
NEXTAUTH_URL="https://your-service-name.onrender.com"

# Optional: if internal URL routing differs.
# NEXTAUTH_URL_INTERNAL="http://127.0.0.1:10000"

# -----------------------------------------------------
# Required: Protected Cron Endpoints
# -----------------------------------------------------
CRON_SECRET="replace-with-long-random-string"

# -----------------------------------------------------
# Optional: Emergency PIN Fallback
# -----------------------------------------------------
FALLBACK_PIN="1006"
ALLOW_PIN_FALLBACK="false"

# -----------------------------------------------------
# Optional: Seed Workbook Path
# -----------------------------------------------------
# Used only by `npm run seed` if you bootstrap from an Excel file.
PRODUCT_BOOTSTRAP_XLSX="../MV PHYSICAL STOCK SHEET-29-03-2026 To 06-03-2026.xlsx"

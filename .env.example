# Database (Neon)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&pgbouncer=true&connect_timeout=15"
DIRECT_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require&connect_timeout=15"

# Auth
NEXTAUTH_SECRET="replace-with-random-32-plus-char-secret"
NEXTAUTH_URL="https://your-render-service.onrender.com"

# Cron
CRON_SECRET="replace-with-long-random-string"

# Emergency fallback login
FALLBACK_PIN="1006"
ALLOW_PIN_FALLBACK="false"

# Optional bootstrap workbook path used by prisma/seed.ts
PRODUCT_BOOTSTRAP_XLSX="../MV PHYSICAL STOCK SHEET-29-03-2026 To 06-03-2026.xlsx"

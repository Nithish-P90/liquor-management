generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-arm64-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── ENUMS ───────────────────────────────────────────────────────────────────

enum Category {
  BRANDY
  WHISKY
  RUM
  VODKA
  GIN
  WINE
  PREMIX
  BEER
  BEVERAGE
  MISCELLANEOUS
}

enum Role {
  ADMIN
  CASHIER
  HELPER
  LOADER
  COLLECTOR
  CLEANER
  OTHER
}

enum PayrollType {
  SALARY
  DAILY
}
enum StockEntryType {
  OPENING
  CLOSING
}

enum IndentStatus {
  PENDING
  PARTIAL
  FULLY_RECEIVED
}

enum PaymentMode {
  CASH
  CARD
  UPI
  CREDIT
  SPLIT
}

enum ScanMethod {
  BARCODE_USB
  BARCODE_CAMERA
  MANUAL
}

enum AdjustmentType {
  BREAKAGE
  RETURN
  THEFT_WRITEOFF
  CORRECTION
}

enum Severity {
  OK
  LOW
  HIGH
}

// ─── PRODUCTS ────────────────────────────────────────────────────────────────

model Product {
  id          Int           @id @default(autoincrement())
  itemCode    String        @unique
  name        String
  category    Category
  sizes       ProductSize[]
  indentItems IndentItem[]
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
}

model ProductSize {
  id             Int               @id @default(autoincrement())
  product        Product           @relation(fields: [productId], references: [id])
  productId      Int
  sizeMl         Int
  bottlesPerCase Int
  barcode        String?           @unique
  mrp            Decimal           @db.Decimal(10, 2)
  sellingPrice   Decimal           @db.Decimal(10, 2)
  stockEntries   StockEntry[]
  receiptItems   ReceiptItem[]
  sales          Sale[]
  adjustments    StockAdjustment[]
  variances      VarianceRecord[]
  indentItems    IndentItem[]
  createdAt      DateTime          @default(now())

  @@unique([productId, sizeMl])
}

// ─── STAFF ───────────────────────────────────────────────────────────────────

model Staff {
  id           Int                @id @default(autoincrement())
  name         String
  email        String?            @unique
  passwordHash String?
  pin          String?            @unique
  role         Role
  payrollType  PayrollType        @default(SALARY)
  monthlySalary Decimal?         @db.Decimal(12, 2)
  dailyWage     Decimal?         @db.Decimal(10, 2)
  active             Boolean            @default(true)
  fingerprintTemplate String?           @db.Text
  sales              Sale[]
  adjustments        StockAdjustment[]  @relation("CreatedBy")
  approvals          StockAdjustment[]  @relation("ApprovedBy")
  sessions           InventorySession[]
  receipts           Receipt[]
  attendanceLogs     AttendanceLog[]
  createdAt          DateTime           @default(now())
}

// ─── ATTENDANCE LOG ─────────────────────────────────────────────────────────

model AttendanceLog {
  id           Int      @id @default(autoincrement())
  staff        Staff    @relation(fields: [staffId], references: [id])
  staffId      Int
  date         DateTime @db.Date
  checkIn      DateTime
  checkOut     DateTime?
  status       String   @default("PRESENT")
  createdAt    DateTime @default(now())

  @@unique([staffId, date])
}

// ─── INVENTORY SESSIONS (Accounting Periods) ─────────────────────────────────

model InventorySession {
  id           Int          @id @default(autoincrement())
  periodStart  DateTime     @db.Date
  periodEnd    DateTime     @db.Date
  createdBy    Staff        @relation(fields: [staffId], references: [id])
  staffId      Int
  locked       Boolean      @default(false)
  stockEntries StockEntry[]
  createdAt    DateTime     @default(now())
}

model StockEntry {
  id            Int              @id @default(autoincrement())
  session       InventorySession @relation(fields: [sessionId], references: [id])
  sessionId     Int
  productSize   ProductSize      @relation(fields: [productSizeId], references: [id])
  productSizeId Int
  entryType     StockEntryType
  cases         Int              @default(0)
  bottles       Int              @default(0)
  totalBottles  Int

  @@unique([sessionId, productSizeId, entryType])
}

// ─── INDENT & RECEIPT (Procurement) ──────────────────────────────────────────

model Indent {
  id            Int          @id @default(autoincrement())
  indentNumber  String       @unique
  invoiceNumber String
  retailerId    String
  retailerName  String
  indentDate    DateTime     @db.Date
  pdfPath       String
  status        IndentStatus @default(PENDING)
  items         IndentItem[]
  receipts      Receipt[]
  createdAt     DateTime     @default(now())
}

model IndentItem {
  id              Int         @id @default(autoincrement())
  indent          Indent      @relation(fields: [indentId], references: [id])
  indentId        Int
  product         Product     @relation(fields: [productId], references: [id])
  productId       Int
  productSize     ProductSize @relation(fields: [productSizeId], references: [id])
  productSizeId   Int
  ratePerCase     Decimal     @db.Decimal(10, 2)
  isRationed      Boolean     @default(false)
  indentCases     Int
  indentBottles   Int
  indentAmount    Decimal     @db.Decimal(10, 2)
  cnfCases        Int
  cnfBottles      Int
  cnfAmount       Decimal     @db.Decimal(10, 2)
  receivedCases   Int         @default(0)
  receivedBottles Int         @default(0)
}

model Receipt {
  id           Int           @id @default(autoincrement())
  indent       Indent        @relation(fields: [indentId], references: [id])
  indentId     Int
  receivedDate DateTime      @db.Date
  receivedBy   Staff         @relation(fields: [staffId], references: [id])
  staffId      Int
  notes        String?
  items        ReceiptItem[]
  createdAt    DateTime      @default(now())
}

model ReceiptItem {
  id              Int         @id @default(autoincrement())
  receipt         Receipt     @relation(fields: [receiptId], references: [id])
  receiptId       Int
  productSize     ProductSize @relation(fields: [productSizeId], references: [id])
  productSizeId   Int
  casesReceived   Int
  bottlesReceived Int
  totalBottles    Int
}

// ─── SALES ───────────────────────────────────────────────────────────────────

model Sale {
  id               Int         @id @default(autoincrement())
  saleDate         DateTime    @db.Date
  saleTime         DateTime
  staff            Staff       @relation(fields: [staffId], references: [id])
  staffId          Int
  productSize      ProductSize @relation(fields: [productSizeId], references: [id])
  productSizeId    Int
  quantityBottles  Int
  sellingPrice     Decimal     @db.Decimal(10, 2)
  totalAmount      Decimal     @db.Decimal(10, 2)
  paymentMode      PaymentMode
  // Split payment breakdown (optional — only set when paymentMode = SPLIT)
  cashAmount       Decimal?    @db.Decimal(10, 2)
  cardAmount       Decimal?    @db.Decimal(10, 2)
  upiAmount        Decimal?    @db.Decimal(10, 2)
  scanMethod       ScanMethod
  customerName     String?
  isManualOverride Boolean     @default(false)
  overrideReason   String?
  createdAt        DateTime    @default(now())
}

// ─── STOCK ADJUSTMENTS ───────────────────────────────────────────────────────

model StockAdjustment {
  id              Int            @id @default(autoincrement())
  adjustmentDate  DateTime       @db.Date
  productSize     ProductSize    @relation(fields: [productSizeId], references: [id])
  productSizeId   Int
  adjustmentType  AdjustmentType
  quantityBottles Int
  reason          String
  createdBy       Staff          @relation("CreatedBy", fields: [createdById], references: [id])
  createdById     Int
  approvedBy      Staff?         @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedById    Int?
  approved        Boolean        @default(false)
  createdAt       DateTime       @default(now())
}

// ─── VARIANCE & ALERTS ───────────────────────────────────────────────────────

model VarianceRecord {
  id              Int         @id @default(autoincrement())
  recordDate      DateTime    @db.Date
  productSize     ProductSize @relation(fields: [productSizeId], references: [id])
  productSizeId   Int
  expectedBottles Int
  actualBottles   Int
  variance        Int
  severity        Severity
  resolved        Boolean     @default(false)
  resolvedNote    String?
  createdAt       DateTime    @default(now())

  @@unique([recordDate, productSizeId])
}

// ─── CASH RECONCILIATION ─────────────────────────────────────────────────────

model CashRecord {
  id              Int      @id @default(autoincrement())
  recordDate      DateTime @db.Date @unique
  // Counter / Register (galla)
  openingRegister Decimal  @db.Decimal(12, 2) @default(0) // carries from prev day's closing
  cashSales       Decimal  @db.Decimal(12, 2) @default(0)
  expenses        Decimal  @db.Decimal(12, 2) @default(0)
  cashToLocker    Decimal  @db.Decimal(12, 2) @default(0) // daily transfer to safe/locker
  closingRegister Decimal  @db.Decimal(12, 2) @default(0) // physical count at end of day
  // Digital payments (reference only)
  cardSales       Decimal  @db.Decimal(12, 2) @default(0)
  upiSales        Decimal  @db.Decimal(12, 2) @default(0)
  creditSales     Decimal  @db.Decimal(12, 2) @default(0)
  creditCollected Decimal  @db.Decimal(12, 2) @default(0)
  notes           String?
  createdAt       DateTime @default(now())
  // Locker balance is computed: sum(cashToLocker) - sum(BankTransaction deposits + KSBCL payments)
}

// Bank deposits and KSBCL payments — event-based (happens every ~3 days)
enum BankTxType {
  DEPOSIT
  KSBCL_PAYMENT
}

model BankTransaction {
  id        Int        @id @default(autoincrement())
  txDate    DateTime   @db.Date
  txType    BankTxType
  amount    Decimal    @db.Decimal(12, 2)
  notes     String?
  createdAt DateTime   @default(now())
}

model Expenditure {
  id          Int      @id @default(autoincrement())
  expDate     DateTime @db.Date
  particulars String
  category    String   @default("OTHER")
  amount      Decimal  @db.Decimal(10, 2)
  createdAt   DateTime @default(now())
}

// ─── NOTIFICATIONS ───────────────────────────────────────────────────────────

model Notification {
  id        Int      @id @default(autoincrement())
  type      String   // PRICE_DECREASE | LOW_STOCK | SYSTEM
  title     String
  body      String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

// ─── SETTINGS ────────────────────────────────────────────────────────────────

model Setting {
  id    Int    @id @default(autoincrement())
  key   String @unique
  value String
}

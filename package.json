{
  "name": "liquor-management",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit",
    "check": "npm run lint && npm run typecheck && npm test",
    "collab:check": "tsx scripts/collab-check.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:push": "prisma db push",
    "seed": "tsx prisma/seed.ts",
    "seed:excel": "tsx prisma/seed.ts --excel ../MV PHYSICAL STOCK SHEET-29-03-2026 To 06-03-2026.xlsx",
    "setup:face-models": "tsx scripts/setup-face-models.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "render:build": "npm run prisma:generate && npm run prisma:migrate && npm run build"
  },
  "dependencies": {
    "@prisma/client": "^5.22.0",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
